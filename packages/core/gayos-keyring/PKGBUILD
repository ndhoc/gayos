pkgname=gayos-keyring
pkgver=0.1.0
pkgrel=1
pkgdesc="Keyring package for GayOS package signing"
arch=('any')
url="https://os.18.io.vn/gayos"
license=('GPL-3.0-or-later')
depends=('pacman')
install="$pkgname.install"
source=(
  'gayos.gpg'
  'gayos-trusted'
  'gayos-revoked'
)
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
  install -Dm644 gayos.gpg "$pkgdir/usr/share/pacman/keyrings/gayos.gpg"
  install -Dm644 gayos-trusted "$pkgdir/usr/share/pacman/keyrings/gayos-trusted"
  install -Dm644 gayos-revoked "$pkgdir/usr/share/pacman/keyrings/gayos-revoked"
}
